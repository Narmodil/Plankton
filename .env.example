# Application Configuration
NEXT_PUBLIC_APP_NAME=Plankton
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_APP_DESCRIPTION="Decentralized Agent Ecosystem"

# API Configuration
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web3 Configuration
NEXT_PUBLIC_WEB3_PROVIDER=https://polygon-mumbai.infura.io/v3/your-project-id
NEXT_PUBLIC_AGENTCOIN_CONTRACT=
NEXT_PUBLIC_NETWORK_ID=80001
NEXT_PUBLIC_CHAIN_NAME=Polygon Mumbai

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/plankton
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=plankton
DATABASE_USER=username
DATABASE_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# IPFS Configuration
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=your-infura-project-id
IPFS_PROJECT_SECRET=your-infura-project-secret

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://plankton-ecosystem.ai

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_WEB3=true
ENABLE_MARKETPLACE=true
ENABLE_SOCIAL=true
ENABLE_ANALYTICS=false

# Monitoring
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# Development
NODE_ENV=development
DEBUG=true

# Production
# NODE_ENV=production
# DEBUG=false